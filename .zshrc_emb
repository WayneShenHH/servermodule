alias egc="cd ~/projects/emb/gameconnector"
alias c:egc="code ~/projects/emb/gameconnector"

alias:ebe="cd ~/projects/emb/backendmodules"
alias c:ebe="code ~/projects/emb/backendmodules"
function u:ebe(){
